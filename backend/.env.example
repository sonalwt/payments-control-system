NODE_ENV=development
PORT=4000
API_PREFIX=api/v1

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=pcs
DB_SCHEMA=public
DB_SYNCHRONIZE=false
DB_LOGGING=false

# JWT
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=8h

# Employee self-service portal (passwordless OTP login)
EMPLOYEE_JWT_EXPIRES_IN=2h
EMPLOYEE_OTP_TTL_MINUTES=10
EMPLOYEE_OTP_MAX_ATTEMPTS=5

# CORS
CORS_ORIGIN=http://localhost:3000

# AWS S3 (document storage)
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
# Optional: set only for S3-compatible services (MinIO, LocalStack, etc.)
# AWS_S3_ENDPOINT=http://localhost:9000
# Public base URL of the frontend (used to build links in emails)
FRONTEND_URL=http://localhost:3000

# SMTP (password-reset emails). Leave SMTP_HOST empty to log the reset link
# to the server console instead of sending a real email (dev fallback).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=sonal@firsteconomy.com
SMTP_PASS=lhptwafkqbomwvbs
MAIL_FROM=Payments Control System <no-reply@pcs.local>
