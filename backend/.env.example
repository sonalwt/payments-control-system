NODE_ENV=development
PORT=4000
API_PREFIX=api/v1

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=pcs
DB_SCHEMA=public
DB_SYNCHRONIZE=false
DB_LOGGING=false

# JWT
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=8h

# CORS
CORS_ORIGIN=http://localhost:3000

# Public base URL of the frontend (used to build links in emails)
FRONTEND_URL=http://localhost:3000

# SMTP (password-reset emails). Leave SMTP_HOST empty to log the reset link
# to the server console instead of sending a real email (dev fallback).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Payments Control System <no-reply@pcs.local>
